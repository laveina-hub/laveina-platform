# ===========================================
# Laveina Platform — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Gallabox (WhatsApp OTP & Notifications) ---
GALLABOX_API_KEY=your-gallabox-api-key
GALLABOX_API_SECRET=your-gallabox-api-secret
GALLABOX_API_URL=https://server.gallabox.com/devapi/v1
GALLABOX_CHANNEL_ID=your-gallabox-channel-id

# DEV-ONLY: set GALLABOX_STUB=true to skip real WhatsApp sends and log the
# payload to the console instead. Use this for local iteration when you don't
# have Gallabox credentials, approved Meta templates, or a test phone handy.
# Flip to "false" (or unset) once you want to test real delivery against your
# own WhatsApp number. Must be unset/"false" in staging and production.
# GALLABOX_STUB=true

# Note on phone validation in dev: when NODE_ENV !== "production" (i.e. under
# `next dev`), the booking form's `receiver_phone` / `sender_phone` fields
# accept international E.164 numbers in addition to the Spanish-only format.
# This lets testers without a Spanish SIM enter e.g. +386 30 745 212 to
# receive real WhatsApp test messages. Production builds always enforce the
# strict Spanish regex — no env var required. See src/validations/shipment.schema.ts.

# --- Google Maps (Places API + Geocoding API) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza_xxx

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
